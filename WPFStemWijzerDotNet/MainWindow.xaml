<Window x:Class="WPFStemWijzerDotNet.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WPFStemWijzerDotNet"
        mc:Ignorable="d"
        Title="Stemwijzer Beheer" Height="660" Width="960"
        Background="#F4F6FA"
        FontFamily="Segoe UI">

	<Window.Resources>

		<SolidColorBrush x:Key="PrimaryBrush"  Color="#1A3A6B"/>
		<SolidColorBrush x:Key="AccentBrush"   Color="#2563EB"/>
		<SolidColorBrush x:Key="DangerBrush"   Color="#DC2626"/>
		<SolidColorBrush x:Key="SuccessBrush"  Color="#16A34A"/>
		<SolidColorBrush x:Key="BorderBrush"   Color="#D1D5DB"/>

		<!-- TextBox -->
		<Style TargetType="TextBox">
			<Setter Property="MinHeight" Value="34"/>
			<Setter Property="Padding" Value="8,6"/>
			<Setter Property="FontSize" Value="13"/>
			<Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
			<Setter Property="BorderThickness" Value="1"/>
			<Setter Property="Background" Value="White"/>
			<Setter Property="Foreground" Value="#1E293B"/>
			<Setter Property="VerticalContentAlignment" Value="Center"/>
			<Setter Property="TextWrapping" Value="NoWrap"/>

			<Setter Property="Template">
				<Setter.Value>
					<ControlTemplate TargetType="TextBox">
						<Border Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="4"
                        SnapsToDevicePixels="True">

							<ScrollViewer x:Name="PART_ContentHost"
                                  Margin="0"
                                  VerticalAlignment="Center"/>
						</Border>

						<ControlTemplate.Triggers>
							<Trigger Property="IsFocused" Value="True">
								<Setter Property="BorderBrush"
                                Value="{StaticResource AccentBrush}"/>
							</Trigger>
						</ControlTemplate.Triggers>
					</ControlTemplate>
				</Setter.Value>
			</Setter>
		</Style>

		<!-- ComboBox -->
		<Style TargetType="ComboBox">
			<Setter Property="Height" Value="32"/>
			<Setter Property="Padding" Value="8,4"/>
			<Setter Property="FontSize" Value="13"/>
			<Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
			<Setter Property="BorderThickness" Value="1"/>
			<Setter Property="Background" Value="White"/>
			<Setter Property="Foreground" Value="#1E293B"/>
		</Style>

		<!-- CheckBox -->
		<Style TargetType="CheckBox">
			<Setter Property="FontSize" Value="13"/>
			<Setter Property="Foreground" Value="#1E293B"/>
			<Setter Property="VerticalContentAlignment" Value="Center"/>
			<Setter Property="Margin" Value="0,10,0,0"/>
		</Style>

		<!-- PasswordBox -->
		<Style TargetType="PasswordBox">
			<Setter Property="Height" Value="32"/>
			<Setter Property="Padding" Value="8,4"/>
			<Setter Property="FontSize" Value="13"/>
			<Setter Property="BorderBrush" Value="#D1D5DB"/>
			<Setter Property="BorderThickness" Value="1"/>
			<Setter Property="Background" Value="White"/>
		</Style>

		<!-- DatePicker -->
		<Style TargetType="DatePicker">
			<Setter Property="Height" Value="32"/>
			<Setter Property="FontSize" Value="13"/>
			<Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
			<Setter Property="BorderThickness" Value="1"/>
			<Setter Property="Background" Value="White"/>
		</Style>

		<!-- FieldLabel -->
		<Style x:Key="FieldLabel" TargetType="TextBlock">
			<Setter Property="FontSize" Value="12"/>
			<Setter Property="FontWeight" Value="SemiBold"/>
			<Setter Property="Foreground" Value="#374151"/>
			<Setter Property="Margin" Value="0,8,0,3"/>
		</Style>

		<!-- ID label (readonly hint) -->
		<Style x:Key="IdLabel" TargetType="TextBlock">
			<Setter Property="FontSize" Value="11"/>
			<Setter Property="Foreground" Value="#9CA3AF"/>
			<Setter Property="Margin" Value="0,0,0,6"/>
		</Style>

		<!-- SectionTitle -->
		<Style x:Key="SectionTitle" TargetType="TextBlock">
			<Setter Property="FontSize" Value="13"/>
			<Setter Property="FontWeight" Value="Bold"/>
			<Setter Property="Foreground" Value="{StaticResource PrimaryBrush}"/>
			<Setter Property="Margin" Value="0,0,0,4"/>
		</Style>

		<!-- Knoppen -->
		<Style x:Key="BaseButton" TargetType="Button">
			<Setter Property="Height" Value="32"/>
			<Setter Property="Padding" Value="16,0"/>
			<Setter Property="FontSize" Value="13"/>
			<Setter Property="FontWeight" Value="SemiBold"/>
			<Setter Property="Foreground" Value="White"/>
			<Setter Property="BorderThickness" Value="0"/>
			<Setter Property="Cursor" Value="Hand"/>
			<Setter Property="Template">
				<Setter.Value>
					<ControlTemplate TargetType="Button">
						<Border x:Name="bd" Background="{TemplateBinding Background}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
							<ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
						</Border>
						<ControlTemplate.Triggers>
							<Trigger Property="IsMouseOver" Value="True">
								<Setter TargetName="bd" Property="Opacity" Value="0.85"/>
							</Trigger>
							<Trigger Property="IsPressed" Value="True">
								<Setter TargetName="bd" Property="Opacity" Value="0.70"/>
							</Trigger>
						</ControlTemplate.Triggers>
					</ControlTemplate>
				</Setter.Value>
			</Setter>
		</Style>
		<Style x:Key="AddButton"    TargetType="Button" BasedOn="{StaticResource BaseButton}">
			<Setter Property="Background" Value="{StaticResource SuccessBrush}"/>
		</Style>
		<Style x:Key="EditButton"   TargetType="Button" BasedOn="{StaticResource BaseButton}">
			<Setter Property="Background" Value="{StaticResource AccentBrush}"/>
		</Style>
		<Style x:Key="DeleteButton" TargetType="Button" BasedOn="{StaticResource BaseButton}">
			<Setter Property="Background" Value="{StaticResource DangerBrush}"/>
		</Style>

		<!-- DataGrid -->
		<Style TargetType="DataGrid">
			<Setter Property="Background" Value="White"/>
			<Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
			<Setter Property="BorderThickness" Value="1"/>
			<Setter Property="RowBackground" Value="White"/>
			<Setter Property="AlternatingRowBackground" Value="#F9FAFB"/>
			<Setter Property="HorizontalGridLinesBrush" Value="#E5E7EB"/>
			<Setter Property="VerticalGridLinesBrush" Value="#E5E7EB"/>
			<Setter Property="FontSize" Value="13"/>
			<Setter Property="Foreground" Value="#111827"/>
			<Setter Property="ColumnHeaderHeight" Value="36"/>
			<Setter Property="RowHeight" Value="32"/>
			<Setter Property="SelectionMode" Value="Single"/>
			<Setter Property="AutoGenerateColumns" Value="True"/>
			<Setter Property="CanUserAddRows" Value="False"/>
		</Style>
		<Style TargetType="DataGridColumnHeader">
			<Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
			<Setter Property="Foreground" Value="White"/>
			<Setter Property="FontWeight" Value="SemiBold"/>
			<Setter Property="FontSize" Value="12"/>
			<Setter Property="Padding" Value="10,0"/>
			<Setter Property="BorderBrush" Value="#243F75"/>
			<Setter Property="BorderThickness" Value="0,0,1,0"/>
		</Style>
		<Style TargetType="DataGridRow">
			<Style.Triggers>
				<Trigger Property="IsSelected" Value="True">
					<Setter Property="Background" Value="#DBEAFE"/>
					<Setter Property="Foreground" Value="#1E3A8A"/>
				</Trigger>
				<Trigger Property="IsMouseOver" Value="True">
					<Setter Property="Background" Value="#EFF6FF"/>
				</Trigger>
			</Style.Triggers>
		</Style>

		<!-- TabControl -->
		<Style TargetType="TabControl">
			<Setter Property="Background" Value="Transparent"/>
			<Setter Property="BorderThickness" Value="0"/>
			<Setter Property="Padding" Value="0"/>

			<Setter Property="Template">
				<Setter.Value>
					<ControlTemplate TargetType="TabControl">
						<Grid ClipToBounds="True">

							<Grid.RowDefinitions>
								<RowDefinition Height="Auto"/>
								<RowDefinition Height="*"/>
							</Grid.RowDefinitions>

							<!-- Scrollbare tabs -->
							<ScrollViewer Grid.Row="0"
                                  HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Disabled"
                                  CanContentScroll="False">

								<TabPanel IsItemsHost="True"
                                  Background="Transparent"/>
							</ScrollViewer>

							<!-- Content -->
							<Border Grid.Row="1">
								<ContentPresenter ContentSource="SelectedContent"/>
							</Border>

						</Grid>
					</ControlTemplate>
				</Setter.Value>
			</Setter>
		</Style>
		<Style TargetType="TabItem">
			<Setter Property="FontSize" Value="13"/>
			<Setter Property="FontWeight" Value="SemiBold"/>
			<Setter Property="Foreground" Value="#6B7280"/>
			<Setter Property="Background" Value="Transparent"/>
			<Setter Property="BorderThickness" Value="0"/>
			<Setter Property="Padding" Value="14,9"/>
			<Setter Property="Margin" Value="0,0,2,0"/>
			<Setter Property="Template">
				<Setter.Value>
					<ControlTemplate TargetType="TabItem">
						<Border x:Name="bd" Background="{TemplateBinding Background}"
                                BorderThickness="0,0,0,2" BorderBrush="Transparent"
                                Padding="{TemplateBinding Padding}">
							<ContentPresenter ContentSource="Header"
                                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
						</Border>
						<ControlTemplate.Triggers>
							<Trigger Property="IsSelected" Value="True">
								<Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
								<Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
							</Trigger>
							<Trigger Property="IsMouseOver" Value="True">
								<Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
							</Trigger>
						</ControlTemplate.Triggers>
					</ControlTemplate>
				</Setter.Value>
			</Setter>
		</Style>

		<!-- Kaart -->
		<Style x:Key="Card" TargetType="Border">
			<Setter Property="Background" Value="White"/>
			<Setter Property="CornerRadius" Value="6"/>
			<Setter Property="Padding" Value="16"/>
			<Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
			<Setter Property="BorderThickness" Value="1"/>
		</Style>

		<Style x:Key="Divider" TargetType="Rectangle">
			<Setter Property="Width" Value="1"/>
			<Setter Property="Fill" Value="{StaticResource BorderBrush}"/>
			<Setter Property="VerticalAlignment" Value="Stretch"/>
			<Setter Property="Margin" Value="5,0"/>
		</Style>

	</Window.Resources>

	<Grid>
		<Grid.RowDefinitions>
			<RowDefinition Height="50"/>
			<RowDefinition Height="*"/>
		</Grid.RowDefinitions>

		<!-- Header -->
		<Border Grid.Row="0" Background="{StaticResource PrimaryBrush}">
			<TextBlock Text="Stemwijzer — Beheerpaneel"
                       Foreground="White" FontSize="16" FontWeight="SemiBold"
                       VerticalAlignment="Center" Margin="16,0"/>
		</Border>

		<TabControl Grid.Row="1" Margin="12,8,12,12">

			<!-- ═══ GEBRUIKERS ═══ -->
			<TabItem Header="Gebruikers">
				<Border Style="{StaticResource Card}" Margin="0,6,0,0">
					<Grid>
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="2*"/>
							<ColumnDefinition Width="12"/>
							<ColumnDefinition Width="3*"/>
						</Grid.ColumnDefinitions>
						<DataGrid x:Name="GebruikersGrid" Grid.Column="0" SelectionChanged="Gebruikers_SelectionChanged"/>
						<Rectangle Grid.Column="1" Style="{StaticResource Divider}"/>
						<ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto">
							<StackPanel Margin="8,0,0,0">
								<TextBlock Text="Gebruiker bewerken" Style="{StaticResource SectionTitle}"/>
								<TextBlock Text="ID wordt automatisch ingevuld" Style="{StaticResource IdLabel}"/>

								<TextBlock Text="Username" Style="{StaticResource FieldLabel}"/>
								<TextBox x:Name="GebruikerUsername"/>

								<TextBlock Text="E-mailadres" Style="{StaticResource FieldLabel}"/>
								<TextBox x:Name="GebruikerEmail"/>

								<TextBlock Text="Wachtwoord (password_hash)" Style="{StaticResource FieldLabel}"/>
								<PasswordBox x:Name="GebruikerPassword"/>

								<TextBlock Text="Aangemaakt op (created_at)" Style="{StaticResource FieldLabel}"/>
								<TextBox x:Name="GebruikerCreatedAt" IsReadOnly="False"
                                         Background="#F9FAFB" Foreground="#6B7280"/>

								<StackPanel Orientation="Horizontal" Margin="0,12,0,0">
									<Button Content="Toevoegen"   Width="110" Margin="0,0,6,0" Style="{StaticResource AddButton}" Click="Addgebruiker_click"/>
									<Button Content="Wijzigen"    Width="110" Margin="0,0,6,0" Style="{StaticResource EditButton}" Click="UpdateGebruiker_Click"/>
									<Button Content="Verwijderen" Width="110" Style="{StaticResource DeleteButton}" Click="DeleteGebruiker_Click"/>
								</StackPanel>
							</StackPanel>
						</ScrollViewer>
					</Grid>
				</Border>
			</TabItem>

			<!-- ═══ ADMINS ═══ -->
			<TabItem Header="Admins">
				<Border Style="{StaticResource Card}" Margin="0,6,0,0">
					<Grid>
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="2*"/>
							<ColumnDefinition Width="12"/>
							<ColumnDefinition Width="3*"/>
						</Grid.ColumnDefinitions>
						<DataGrid x:Name="AdminsGrid" Grid.Column="0"
                                />
						<Rectangle Grid.Column="1" Style="{StaticResource Divider}"/>
						<StackPanel Grid.Column="2" Margin="8,0,0,0">
							<TextBlock Text="Admin bewerken" Style="{StaticResource SectionTitle}"/>
							<TextBlock Text="ID wordt automatisch ingevuld" Style="{StaticResource IdLabel}"/>

							<TextBlock Text="Username" Style="{StaticResource FieldLabel}"/>
							<TextBox x:Name="AdminUsername"/>

							<TextBlock Text="Wachtwoord (password_hash)" Style="{StaticResource FieldLabel}"/>
							<PasswordBox x:Name="AdminPassword"/>

							<StackPanel Orientation="Horizontal" Margin="0,12,0,0">
								<Button Content="Toevoegen"   Width="95" Margin="0,0,6,0" Style="{StaticResource AddButton}"
                                                                                        />
								<Button Content="Wijzigen"    Width="90" Margin="0,0,6,0" Style="{StaticResource EditButton}"
                                                                                       />
								<Button Content="Verwijderen" Width="95" Style="{StaticResource DeleteButton}"
                                                                                       />
							</StackPanel>
						</StackPanel>
					</Grid>
				</Border>
			</TabItem>

			<!-- ═══ PARTIJEN ═══ -->
			<TabItem Header="Partijen">
				<Border Style="{StaticResource Card}" Margin="0,6,0,0">
					<Grid>
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="2*"/>
							<ColumnDefinition Width="12"/>
							<ColumnDefinition Width="3*"/>
						</Grid.ColumnDefinitions>
						<DataGrid x:Name="PartijenGrid"
                              Grid.Column="0"
                              SelectionChanged="PartijenGrid_SelectionChanged"/>
						<Rectangle Grid.Column="1" Style="{StaticResource Divider}"/>
						<StackPanel Grid.Column="2" Margin="8,0,0,0">
							<TextBlock Text="Partij bewerken" Style="{StaticResource SectionTitle}"/>
							<TextBlock Text="ID wordt automatisch ingevuld" Style="{StaticResource IdLabel}"/>

							<TextBlock Text="Naam (name)" Style="{StaticResource FieldLabel}"/>
							<TextBox x:Name="PartijNaam"/>

							<TextBlock Text="Logo (bestandsnaam/pad)" Style="{StaticResource FieldLabel}"/>
							<TextBox x:Name="PartijLogo"/>

							<TextBlock Text="Beschrijving (description)" Style="{StaticResource FieldLabel}"/>
							<TextBox x:Name="PartijBeschrijving" Height="85"
                                     AcceptsReturn="True" TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"
                                     VerticalContentAlignment="Top"/>

							<StackPanel Orientation="Horizontal" Margin="0,12,0,0">
								<Button x:Name="BtnToevoegen" Content="Toevoegen"
                                    Width="110" Margin="0,0,6,0"
                                    Style="{StaticResource AddButton}"
                                    Click="BtnPartijToevoegen_Click"/>
								<Button x:Name="BtnWijzigen" Content="Wijzigen"
                                    Width="110" Margin="0,0,6,0"
                                    Style="{StaticResource EditButton}"
                                    Click="BtnPartijWijzigen_Click"/>
								<Button x:Name="BtnVerwijderen" Content="Verwijderen"
                                    Width="110"
                                    Style="{StaticResource DeleteButton}"
                                    Click="BtnPartijVerwijderen_Click"/>
							</StackPanel>
						</StackPanel>
					</Grid>
				</Border>
			</TabItem>

			<!-- ═══ VERKIEZINGEN ═══ -->
			<TabItem Header="Verkiezingen">
				<Border Style="{StaticResource Card}" Margin="0,6,0,0">
					<Grid>
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="2*"/>
							<ColumnDefinition Width="12"/>
							<ColumnDefinition Width="3*"/>
						</Grid.ColumnDefinitions>
						<DataGrid x:Name="VerkiezingenGrid" Grid.Column="0" SelectionChanged="VerkiezingenGrid_SelectionChanged_1"/>
						<Rectangle Grid.Column="1" Style="{StaticResource Divider}"/>
						<StackPanel Grid.Column="2" Margin="8,0,0,0">
							<TextBlock Text="Verkiezing bewerken" Style="{StaticResource SectionTitle}"/>
							<TextBlock Text="ID wordt automatisch ingevuld" Style="{StaticResource IdLabel}"/>

							<TextBlock Text="Naam (name)" Style="{StaticResource FieldLabel}"/>
							<TextBox x:Name="VerkiezingNaam"/>

							<TextBlock Text="Verkiezingsdatum (election_date)" Style="{StaticResource FieldLabel}"/>
							<DatePicker x:Name="VerkiezingDatum"/>

							<CheckBox x:Name="VerkiezingActief" Content="Actief (active)"/>

							<StackPanel Orientation="Horizontal" Margin="0,12,0,0">
								<Button Content="Toevoegen"   Width="95" Margin="0,0,6,0" Style="{StaticResource AddButton}" Click="BtnVerkiezingToevoegen"/>
								<Button Content="Wijzigen"    Width="90" Margin="0,0,6,0" Style="{StaticResource EditButton}" Click="BtnVerkiezingWijzigen"/>
								<Button Content="Verwijderen" Width="95" Margin="0,0,6,0" Style="{StaticResource DeleteButton}" Click="BtnVerkiezingVerwijderen"/>
							</StackPanel>
						</StackPanel>
					</Grid>
				</Border>
			</TabItem>

			<!-- ═══ VRAGEN ═══ -->
			<TabItem Header="Vragen">
				<Border Style="{StaticResource Card}" Margin="0,6,0,0">
					<Grid>
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="2*"/>
							<ColumnDefinition Width="12"/>
							<ColumnDefinition Width="3*"/>
						</Grid.ColumnDefinitions>
						<DataGrid x:Name="VragenGrid" Grid.Column="0"/>
						<Rectangle Grid.Column="1" Style="{StaticResource Divider}"/>
						<StackPanel Grid.Column="2" Margin="8,0,0,0">
							<TextBlock Text="Vraag bewerken" Style="{StaticResource SectionTitle}"/>
							<TextBlock Text="ID wordt automatisch ingevuld" Style="{StaticResource IdLabel}"/>

							<TextBlock Text="Verkiezing (election_id)" Style="{StaticResource FieldLabel}"/>
							<ComboBox x:Name="VraagVerkiezing"/>

							<TextBlock Text="Vraagtekst (question_text)" Style="{StaticResource FieldLabel}"/>
							<TextBox x:Name="VraagTekst" Height="85"
                                     AcceptsReturn="True" TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"
                                     VerticalContentAlignment="Top"/>

							<StackPanel Orientation="Horizontal" Margin="0,12,0,0">
								<Button Content="Toevoegen"   Width="95" Margin="0,0,6,0" Style="{StaticResource AddButton}"/>
								<Button Content="Wijzigen"    Width="90" Margin="0,0,6,0" Style="{StaticResource EditButton}"/>
								<Button Content="Verwijderen" Width="95" Style="{StaticResource DeleteButton}"/>
							</StackPanel>
						</StackPanel>
					</Grid>
				</Border>
			</TabItem>

			<!-- ═══ PARTIJ ANTWOORDEN ═══ -->
			<TabItem Header="Partij antwoorden">
				<Border Style="{StaticResource Card}" Margin="0,6,0,0">
					<Grid>
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="2*"/>
							<ColumnDefinition Width="12"/>
							<ColumnDefinition Width="3*"/>
						</Grid.ColumnDefinitions>
						<DataGrid x:Name="PartijAntwoordenGrid" Grid.Column="0"/>
						<Rectangle Grid.Column="1" Style="{StaticResource Divider}"/>
						<StackPanel Grid.Column="2" Margin="8,0,0,0">
							<TextBlock Text="Partij antwoord bewerken" Style="{StaticResource SectionTitle}"/>
							<TextBlock Text="ID wordt automatisch ingevuld" Style="{StaticResource IdLabel}"/>

							<TextBlock Text="Partij (party_id)" Style="{StaticResource FieldLabel}"/>
							<ComboBox x:Name="PAntwoordPartij"/>

							<TextBlock Text="Vraag (question_id)" Style="{StaticResource FieldLabel}"/>
							<ComboBox x:Name="PAntwoordVraag"/>

							<TextBlock Text="Antwoord (answer)" Style="{StaticResource FieldLabel}"/>
							<ComboBox x:Name="PAntwoordAntwoord">
								<ComboBoxItem Content="eens"/>
								<ComboBoxItem Content="oneens"/>
							</ComboBox>

							<StackPanel Orientation="Horizontal" Margin="0,12,0,0">
								<Button Content="Toevoegen"   Width="95" Margin="0,0,6,0" Style="{StaticResource AddButton}"/>
								<Button Content="Wijzigen"    Width="90" Margin="0,0,6,0" Style="{StaticResource EditButton}"/>
								<Button Content="Verwijderen" Width="95" Style="{StaticResource DeleteButton}"/>
							</StackPanel>
						</StackPanel>
					</Grid>
				</Border>
			</TabItem>

			<!-- ═══ GEBRUIKER ANTWOORDEN ═══ -->
			<TabItem Header="Gebruiker antwoorden">
				<Border Style="{StaticResource Card}" Margin="0,6,0,0">
					<Grid>
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="2*"/>
							<ColumnDefinition Width="12"/>
							<ColumnDefinition Width="3*"/>
						</Grid.ColumnDefinitions>
						<DataGrid x:Name="UserAntwoordenGrid" Grid.Column="0"/>
						<Rectangle Grid.Column="1" Style="{StaticResource Divider}"/>
						<StackPanel Grid.Column="2" Margin="8,0,0,0">
							<TextBlock Text="Gebruiker antwoord bewerken" Style="{StaticResource SectionTitle}"/>
							<TextBlock Text="ID wordt automatisch ingevuld" Style="{StaticResource IdLabel}"/>

							<TextBlock Text="Gebruiker (user_id)" Style="{StaticResource FieldLabel}"/>
							<ComboBox x:Name="UAntwoordGebruiker"/>

							<TextBlock Text="Vraag (question_id)" Style="{StaticResource FieldLabel}"/>
							<ComboBox x:Name="UAntwoordVraag"/>

							<TextBlock Text="Antwoord (answer)" Style="{StaticResource FieldLabel}"/>
							<ComboBox x:Name="UAntwoordAntwoord">
								<ComboBoxItem Content="eens"/>
								<ComboBoxItem Content="oneens"/>
							</ComboBox>

							<StackPanel Orientation="Horizontal" Margin="0,12,0,0">
								<Button Content="Toevoegen"   Width="95" Margin="0,0,6,0" Style="{StaticResource AddButton}"/>
								<Button Content="Wijzigen"    Width="90" Margin="0,0,6,0" Style="{StaticResource EditButton}"/>
								<Button Content="Verwijderen" Width="95" Style="{StaticResource DeleteButton}"/>
							</StackPanel>
						</StackPanel>
					</Grid>
				</Border>
			</TabItem>

			<!-- ═══ RESULTATEN ═══ -->
			<TabItem Header="Resultaten">
				<Border Style="{StaticResource Card}" Margin="0,6,0,0">
					<Grid>
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="2*"/>
							<ColumnDefinition Width="12"/>
							<ColumnDefinition Width="3*"/>
						</Grid.ColumnDefinitions>
						<DataGrid x:Name="ResultatenGrid" Grid.Column="0"/>
						<Rectangle Grid.Column="1" Style="{StaticResource Divider}"/>
						<StackPanel Grid.Column="2" Margin="8,0,0,0">
							<TextBlock Text="Resultaat bewerken" Style="{StaticResource SectionTitle}"/>
							<TextBlock Text="ID wordt automatisch ingevuld" Style="{StaticResource IdLabel}"/>

							<TextBlock Text="Gebruiker (user_id)" Style="{StaticResource FieldLabel}"/>
							<ComboBox x:Name="ResultaatGebruiker"/>

							<TextBlock Text="Partij (party_id)" Style="{StaticResource FieldLabel}"/>
							<ComboBox x:Name="ResultaatPartij"/>

							<TextBlock Text="Overeenkomst % (percentage)" Style="{StaticResource FieldLabel}"/>
							<TextBox x:Name="ResultaatPercentage"/>

							<TextBlock Text="Aangemaakt op (created_at)" Style="{StaticResource FieldLabel}"/>
							<TextBox x:Name="ResultaatCreatedAt" IsReadOnly="True"
                                     Background="#F9FAFB" Foreground="#6B7280"/>

							<StackPanel Orientation="Horizontal" Margin="0,12,0,0">
								<Button Content="Toevoegen"   Width="95" Margin="0,0,6,0" Style="{StaticResource AddButton}"/>
								<Button Content="Wijzigen"    Width="90" Margin="0,0,6,0" Style="{StaticResource EditButton}"/>
								<Button Content="Verwijderen" Width="95" Style="{StaticResource DeleteButton}"/>
							</StackPanel>
						</StackPanel>
					</Grid>
				</Border>
			</TabItem>

			<!-- ═══ NIEUWS ═══ -->
			<TabItem Header="Nieuws">
				<Border Style="{StaticResource Card}" Margin="0,6,0,0">
					<Grid>
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="2*"/>
							<ColumnDefinition Width="12"/>
							<ColumnDefinition Width="3*"/>
						</Grid.ColumnDefinitions>
						<DataGrid x:Name="NieuwsGrid" Grid.Column="0" SelectionChanged="NieuwsGrid_SelectionChanged"/>
						<Rectangle Grid.Column="1" Style="{StaticResource Divider}"/>
						<StackPanel Grid.Column="2" Margin="8,0,0,0">
							<TextBlock Text="Nieuwsbericht bewerken" Style="{StaticResource SectionTitle}"/>
							<TextBlock Text="ID wordt automatisch ingevuld" Style="{StaticResource IdLabel}"/>

							<TextBlock Text="Titel (title)" Style="{StaticResource FieldLabel}"/>
							<TextBox x:Name="NieuwsTitel"/>

							<TextBlock Text="Afbeelding (image, bestandsnaam/pad)" Style="{StaticResource FieldLabel}"/>
							<TextBox x:Name="NieuwsImage"/>

							<TextBlock Text="Inhoud (content)" Style="{StaticResource FieldLabel}"/>
							<TextBox x:Name="NieuwsContent" Height="85"
                                     AcceptsReturn="True" TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"
                                     VerticalContentAlignment="Top"/>

							<TextBlock Text="Aangemaakt op (created_at)" Style="{StaticResource FieldLabel}"/>
							<TextBox Text="{Binding CreatedAt, StringFormat=s}" x:Name="NieuwsCreatedAt" IsReadOnly="false"
                                     Background="#F9FAFB" Foreground="#6B7280" />

							<StackPanel Orientation="Horizontal" Margin="0,12,0,0">
								<Button Content="Toevoegen"   Width="110" Margin="0,0,6,0" Style="{StaticResource AddButton}" Click="BtnNieuwsToevoegen"/>
								<Button Content="Wijzigen"    Width="110" Margin="0,0,6,0" Style="{StaticResource EditButton}" Click="BtnNieuwsWijzigen"/>
								<Button Content="Verwijderen" Width="110" Style="{StaticResource DeleteButton}" Click="BtnNieuwsVerwijderen"/>
							</StackPanel>
						</StackPanel>
					</Grid>
				</Border>
			</TabItem>

			<!-- ═══ REACTIES (comments) ═══ -->
			<TabItem Header="Reacties">
				<Border Style="{StaticResource Card}" Margin="0,6,0,0">
					<Grid>
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="2*"/>
							<ColumnDefinition Width="12"/>
							<ColumnDefinition Width="3*"/>
						</Grid.ColumnDefinitions>
						<DataGrid x:Name="ReactiesGrid" Grid.Column="0" SelectionChanged="ReactiesGrid_SelectionChanged"/>
						<Rectangle Grid.Column="1" Style="{StaticResource Divider}"/>
						<StackPanel Grid.Column="2" Margin="8,0,0,0">
							<TextBlock Text="Reactie bewerken" Style="{StaticResource SectionTitle}"/>
							<TextBlock Text="ID wordt automatisch ingevuld" Style="{StaticResource IdLabel}"/>

							<TextBlock Text="Nieuwsbericht (news_id)" Style="{StaticResource FieldLabel}"/>
							<ComboBox x:Name="ReactieNieuws" DisplayMemberPath="title" SelectedValuePath="id" SelectionChanged="ReactieNieuws_SelectionChanged"/>

							<TextBlock Text="Gebruiker (user_id)" Style="{StaticResource FieldLabel}"/>
							<ComboBox x:Name="ReactieGebruiker" DisplayMemberPath="username" SelectedValuePath="id" SelectionChanged="ReactieGebruiker_SelectionChanged" />

							<TextBlock Text="Reactie tekst (comment_text)" Style="{StaticResource FieldLabel}"/>
							<TextBox x:Name="ReactieTekst" Height="85"
                                     AcceptsReturn="True" TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"
                                     VerticalContentAlignment="Top"/>

							<TextBlock Text="Aangemaakt op (created_at)" Style="{StaticResource FieldLabel}"/>
							<TextBox x:Name="ReactieCreatedAt" IsReadOnly="True"
                                     Background="#F9FAFB" Foreground="#6B7280"/>

							<StackPanel Orientation="Horizontal" Margin="0,12,0,0">
								<Button Content="Toevoegen"   Width="95" Margin="0,0,6,0" Style="{StaticResource AddButton}" Click="AddReactie_Click"/>
								<Button Content="Wijzigen"    Width="90" Margin="0,0,6,0" Style="{StaticResource EditButton}" Click="UpdateReactie_Click"/>
								<Button Content="Verwijderen" Width="95" Style="{StaticResource DeleteButton}" Click="DeleteReactie_Click"/>
							</StackPanel>
						</StackPanel>
					</Grid>
				</Border>
			</TabItem>

		</TabControl>
	</Grid>
</Window>

